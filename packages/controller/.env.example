# --- Controller configuration ---
DATABASE_URL=postgresql://cbm:cbm@localhost:5544/cbm

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Secret-at-rest master key (base64, 32 bytes). Falls back to BETTER_AUTH_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Agent image referenced by the install command + GET /install.sh.
AGENT_IMAGE=ghcr.io/holo795/cbm-agent
AGENT_IMAGE_TAG=latest

# URL agents dial to reach the controller. Falls back to BETTER_AUTH_URL;
# only set if it differs (e.g. http://host.docker.internal:3000 in local dev).
AGENT_CONTROLLER_URL=

# No admin seed: the first person to register becomes the admin, then sign-up
# closes automatically. Just open the site and create your account.

# --- Email (SMTP) ---
# Optional: enables password reset + account verification. You can also set this
# from Settings → Email in the UI; any value here overrides the UI and locks it.
# For local dev, `docker compose -f docker-compose.dev.yml up -d` starts Mailpit;
# uncomment these to catch all mail at http://localhost:8025
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=cbm@dev.local
# SMTP_FROM_NAME=CBM (dev)

# Optional OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
